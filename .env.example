# Optional live Omnigent smoke gate.
# Default verification keeps this disabled, so no credentials required are
# needed for CI or routine local runs.
OMNIAGENT_PLUS_LIVE_OMNIGENT=0

# required when OMNIAGENT_PLUS_LIVE_OMNIGENT=1
OMNIAGENT_PLUS_LIVE_OMNIGENT_BASE_URL=http://127.0.0.1:8080

# optional when the selected live endpoint requires auth
OMNIAGENT_PLUS_LIVE_OMNIGENT_BEARER_TOKEN=replace-with-local-redacted-token
